import { useState, useRef, ChangeEvent } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Leaf, 
  Upload, 
  Droplets, 
  Sun, 
  Info, 
  Sprout, 
  AlertCircle, 
  Camera, 
  X,
  ArrowLeft,
  Loader2
} from 'lucide-react';
import { identifyPlant, PlantInfo } from './services/geminiService';

export default function App() {
  const [image, setImage] = useState<string | null>(null);
  const [plantInfo, setPlantInfo] = useState<PlantInfo | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleImageUpload = (e: ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      if (file.size > 5 * 1024 * 1024) {
        setError("Image is too large. Please upload an image smaller than 5MB.");
        return;
      }
      
      const reader = new FileReader();
      reader.onloadend = () => {
        const base64String = reader.result as string;
        setImage(base64String);
        analyzeImage(base64String.split(',')[1]);
      };
      reader.readAsDataURL(file);
    }
  };

  const analyzeImage = async (base64: string) => {
    setIsLoading(true);
    setError(null);
    try {
      const info = await identifyPlant(base64);
      setPlantInfo(info);
    } catch (err) {
      console.error(err);
      setError("We couldn't identify this plant. Please try a clearer picture of the leaves or flowers.");
    } finally {
      setIsLoading(false);
    }
  };

  const reset = () => {
    setImage(null);
    setPlantInfo(null);
    setError(null);
    setIsLoading(false);
  };

  const triggerUpload = () => fileInputRef.current?.click();

  return (
    <div className="min-h-screen flex flex-col bg-natural-50 text-natural-700">
      {/* Navigation */}
      <nav className="w-full py-6 px-4 md:px-10 flex items-center justify-between border-b border-natural-200 bg-white/50 backdrop-blur-small sticky top-0 z-10 transition-all">
        <div className="flex items-center gap-3">
          <div className="w-10 h-10 bg-natural-600 rounded-full flex items-center justify-center shadow-lg shadow-natural-600/10">
            <Leaf className="w-6 h-6 text-white" />
          </div>
          <div>
            <h1 className="text-xl font-bold tracking-tight text-natural-900">CropSnap Advisor</h1>
            <p className="text-[10px] uppercase tracking-widest text-natural-500 font-bold leading-none mt-0.5">Agriculture Intelligence</p>
          </div>
        </div>
        
        <div className="flex items-center gap-6">
          {(image || plantInfo) && !isLoading && (
            <button 
              onClick={reset}
              className="text-xs font-bold uppercase tracking-wider text-natural-600 underline underline-offset-4 hover:text-natural-900 transition-colors"
            >
              Start New Scan
            </button>
          )}
          <div className="hidden md:flex gap-6 text-sm font-medium opacity-70">
            <span>Guide</span>
            <span>Recent</span>
          </div>
        </div>
      </nav>

      <main className="flex-1 max-w-6xl mx-auto w-full p-4 md:p-10">
        <AnimatePresence mode="wait">
          {!image && !isLoading && (
            <motion.div
              key="upload"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.95 }}
              className="grid grid-cols-1 lg:grid-cols-12 gap-10 h-full"
            >
              <div className="lg:col-span-5 flex flex-col gap-6">
                <div 
                  onClick={triggerUpload}
                  className="relative flex-1 aspect-[4/5] bg-natural-100 rounded-[32px] border-2 border-dashed border-natural-500 flex flex-col items-center justify-center overflow-hidden cursor-pointer hover:bg-natural-50 transition-all group"
                >
                  <div className="flex flex-col items-center justify-center gap-4 group-hover:scale-105 transition-transform duration-500">
                    <div className="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-sm">
                      <Camera className="w-10 h-10 text-natural-600" />
                    </div>
                    <div className="text-center px-6">
                      <p className="text-xl font-bold text-natural-900">Upload Crop Photo</p>
                      <p className="text-natural-500 mt-2 text-sm">Select a clear photo of the leaves or flowers for best identification</p>
                    </div>
                  </div>
                  <input 
                    type="file" 
                    ref={fileInputRef}
                    onChange={handleImageUpload}
                    accept="image/*"
                    className="hidden"
                  />
                </div>
                <button 
                  onClick={triggerUpload}
                  className="w-full py-5 bg-natural-600 hover:bg-natural-700 text-white rounded-2xl font-bold text-lg shadow-lg shadow-natural-600/10 transition-all active:scale-[0.98]"
                >
                  Capture New Crop
                </button>
              </div>

              <div className="lg:col-span-7 flex flex-col justify-center gap-8">
                <div className="space-y-4">
                  <span className="text-xs font-bold uppercase tracking-widest text-natural-500">How it works</span>
                  <h2 className="text-4xl md:text-5xl font-bold text-natural-900 leading-tight">Identify and care for your crops instantly.</h2>
                  <p className="text-lg text-natural-600 leading-relaxed max-w-xl">
                    Our AI advisor helps farmers and enthusiasts understand their plants better with simple, actionable advice on soil, water, and growth techniques.
                  </p>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <TipItem icon={<Sun className="w-5 h-5" />} text="Outdoor plants grow best in clear light" />
                  <TipItem icon={<Droplets className="w-5 h-5" />} text="Photograph leaves in focus for best results" />
                </div>
              </div>
            </motion.div>
          )}

          {isLoading && (
            <motion.div
              key="loading"
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="flex-1 flex flex-col items-center justify-center gap-8 text-center min-h-[60vh]"
            >
              <div className="relative">
                <motion.div 
                  className="w-32 h-32 border-2 border-natural-200 rounded-full"
                  animate={{ scale: [1, 1.05, 1], rotate: 360 }}
                  transition={{ duration: 3, repeat: Infinity, ease: "linear" }}
                />
                <Loader2 className="w-12 h-12 text-natural-600 absolute inset-0 m-auto animate-spin" />
              </div>
              <div>
                <h2 className="text-2xl font-bold text-natural-900">Identifying Crop...</h2>
                <p className="text-natural-500 mt-2 italic font-serif">Analyzing botanical characteristics</p>
              </div>
            </motion.div>
          )}

          {plantInfo && image && !isLoading && (
            <motion.div
              key="results"
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="grid grid-cols-1 lg:grid-cols-12 gap-10"
            >
              <div className="lg:col-span-12">
                <button 
                  onClick={reset}
                  className="inline-flex items-center gap-2 text-natural-600 font-bold text-sm mb-6 hover:text-natural-900 transition-colors group"
                >
                  <ArrowLeft className="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                  Back to captures
                </button>
              </div>

              {/* Sidebar: Image & Action */}
              <div className="lg:col-span-5 flex flex-col gap-6">
                <div className="relative w-full aspect-[4/5] bg-natural-100 rounded-[32px] border border-natural-200 overflow-hidden shadow-sm group">
                  <img src={image} alt="Captured plant" className="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                  <div className="absolute bottom-6 left-6 right-6 p-4 bg-white/90 backdrop-blur-sm rounded-2xl border border-white/50 flex items-center justify-between shadow-sm">
                    <div className="flex items-center gap-3">
                      <div className="w-8 h-8 bg-natural-600 rounded-lg flex items-center justify-center">
                        <svg className="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M5 13l4 4L19 7"/></svg>
                      </div>
                      <span className="text-xs font-bold uppercase tracking-wider text-natural-900">Analysis Complete</span>
                    </div>
                  </div>
                </div>
                <button 
                  onClick={reset}
                  className="w-full py-5 bg-natural-600 hover:bg-natural-700 text-white rounded-2xl font-bold text-lg shadow-lg shadow-natural-600/10 transition-all"
                >
                  Capture New Crop
                </button>
              </div>

              {/* Main Content: Info */}
              <div className="lg:col-span-7 flex flex-col gap-6">
                <div className="bg-white p-6 md:p-10 rounded-[40px] shadow-sm border border-natural-200 h-full flex flex-col">
                  <div className="mb-10">
                    <span className="text-[10px] font-bold uppercase tracking-[0.2em] text-natural-500 mb-2 block">Identification Result</span>
                    <h1 className="text-4xl md:text-5xl font-bold text-natural-900 leading-tight">{plantInfo.name}</h1>
                    <p className="text-xl text-natural-600 italic font-serif mt-1">Species details identified</p>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
                    <div className="flex flex-col gap-2">
                      <span className="text-[10px] font-bold uppercase tracking-widest text-natural-500">Best Soil Type</span>
                      <div className="flex items-center gap-3">
                        <div className="w-3 h-3 rounded-full bg-soil shadow-sm"></div>
                        <span className="text-lg font-semibold text-natural-900">{plantInfo.soilType}</span>
                      </div>
                    </div>

                    <div className="flex flex-col gap-2">
                      <span className="text-[10px] font-bold uppercase tracking-widest text-natural-500">Daily Sunlight</span>
                      <div className="flex items-center gap-3">
                        <div className="w-3 h-3 rounded-full bg-sun shadow-sm"></div>
                        <span className="text-lg font-semibold text-natural-900">{plantInfo.careInstructions.sunlight}</span>
                      </div>
                    </div>

                    <div className="flex flex-col gap-2">
                      <span className="text-[10px] font-bold uppercase tracking-widest text-natural-500">Watering Needs</span>
                      <div className="flex items-center gap-3">
                        <div className="w-3 h-3 rounded-full bg-water shadow-sm"></div>
                        <span className="text-lg font-semibold text-natural-900">{plantInfo.careInstructions.watering}</span>
                      </div>
                    </div>
                  </div>

                  <div className="mt-auto p-6 md:p-8 bg-natural-50 rounded-[32px] border border-natural-200">
                    <div className="flex flex-col md:flex-row items-center md:items-start gap-4 text-center md:text-left">
                      <div className="w-14 h-14 bg-white rounded-2xl flex items-center justify-center shrink-0 text-2xl shadow-sm border border-natural-100">
                        🌱
                      </div>
                      <div>
                        <h4 className="font-bold text-natural-900 text-lg mb-1">Pro Growth Suggestion</h4>
                        <p className="text-natural-600 leading-relaxed">{plantInfo.growthSuggestion}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </motion.div>
          )}

          {error && !isLoading && (
            <motion.div
              key="error"
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="bg-white border border-red-200 p-10 rounded-[40px] shadow-sm flex flex-col items-center gap-6 text-center max-w-xl mx-auto my-10"
            >
              <div className="w-20 h-20 bg-red-50 rounded-full flex items-center justify-center outline outline-8 outline-red-50/50">
                <AlertCircle className="w-10 h-10 text-red-500" />
              </div>
              <div>
                <h3 className="text-2xl font-bold text-natural-900 uppercase tracking-tight">Scan Failed</h3>
                <p className="text-natural-600 mt-2">{error}</p>
              </div>
              <button 
                onClick={reset}
                className="bg-natural-900 hover:bg-black text-white font-bold py-4 px-10 rounded-2xl transition-all shadow-lg active:scale-95"
              >
                Try Another Photo
              </button>
            </motion.div>
          )}
        </AnimatePresence>
      </main>

      <footer className="py-10 border-t border-natural-200 text-center">
        <p className="text-natural-500 text-xs font-bold uppercase tracking-widest">
          &copy; {new Date().getFullYear()} CropSnap Advisor • Precision Agriculture
        </p>
      </footer>
    </div>
  );
}

function InfoCard({ title, content, icon }: { title: string, content: string, icon: React.ReactNode }) {
  return (
    <div className="bg-white p-6 rounded-3xl shadow-sm border border-brand-100 flex items-start gap-4">
      <div className="bg-brand-50 p-3 rounded-2xl shrink-0">
        {icon}
      </div>
      <div>
        <h3 className="text-sm font-bold text-brand-600 uppercase tracking-wider">{title}</h3>
        <p className="text-brand-900 font-medium mt-1 leading-relaxed">{content}</p>
      </div>
    </div>
  );
}

function TipItem({ icon, text }: { icon: React.ReactNode, text: string }) {
  return (
    <div className="flex items-center gap-3 bg-white/50 p-4 rounded-2xl border border-brand-100">
      <div className="text-brand-500">{icon}</div>
      <p className="text-sm text-brand-700 font-medium">{text}</p>
    </div>
  );
}
